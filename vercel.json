
{
  "rewrites": [
    {
      "source": "/api/gemini-proxy",
      "destination": "/api/gemini-proxy"
    },
    {
      "source": "/api/get-okb",
      "destination": "/api/get-okb"
    },
    {
      "source": "/api/get-akb",
      "destination": "/api/get-akb"
    },
    {
      "source": "/api/get-okb-status",
      "destination": "/api/get-okb-status"
    },
    {
      "source": "/api/get-conflict-zones",
      "destination": "/api/get-conflict-zones"
    },
    {
      "source": "/api/get-full-cache",
      "destination": "/api/get-full-cache"
    },
    {
      "source": "/api/add-to-cache",
      "destination": "/api/add-to-cache"
    },
    {
      "source": "/api/update-coords",
      "destination": "/api/update-coords"
    },
    {
      "source": "/api/update-address",
      "destination": "/api/update-address"
    },
    {
      "source": "/api/delete-address",
      "destination": "/api/delete-address"
    },
    {
      "source": "/api/get-cached-address",
      "destination": "/api/get-cached-address"
    },
    {
      "source": "/api/geocode",
      "destination": "/api/geocode"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/get-conflict-zones",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/get-okb",
      "schedule": "0 5 * * *"
    }
  ]
}
