{
  "rewrites": [
    {
      "source": "/api/gemini-proxy",
      "destination": "/api/gemini-proxy"
    },
    {
      "source": "/api/process-sales-data",
      "destination": "/api/process-sales-data"
    },
    {
      "source": "/api/poll-coordinates",
      "destination": "/api/poll-coordinates"
    },
    {
      "source": "/api/get-conflict-zones",
      "destination": "/api/get-conflict-zones"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/get-conflict-zones",
      "schedule": "0 6 * * *"
    }
  ]
}
