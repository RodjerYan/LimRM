
{
  "rewrites": [
    { "source": "/api/gemini-proxy", "destination": "/api/gemini-proxy" },
    { "source": "/api/:path*", "destination": "/api/data?action=:path" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "functions": {
    "api/data.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/gemini-proxy.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
