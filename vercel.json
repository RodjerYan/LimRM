
{
  "rewrites": [
    { "source": "/api/snapshot", "destination": "/api/snapshot" },
    { "source": "/api/gemini-proxy", "destination": "/api/gemini-proxy" },
    { "source": "/api/get-okb", "destination": "/api/data?action=get-okb" },
    { "source": "/api/get-akb", "destination": "/api/data?action=get-akb" },
    { "source": "/api/get-okb-status", "destination": "/api/data?action=get-okb-status" },
    { "source": "/api/get-full-cache", "destination": "/api/registry?action=full-cache" },
    { "source": "/api/get-cached-address", "destination": "/api/registry?action=get-address" },
    { "source": "/api/add-to-cache", "destination": "/api/registry?action=add-to-cache" },
    { "source": "/api/update-coords", "destination": "/api/registry?action=update-coords" },
    { "source": "/api/update-address", "destination": "/api/registry?action=update-address" },
    { "source": "/api/delete-address", "destination": "/api/registry?action=delete-address" },
    { "source": "/api/geocode", "destination": "/api/geocode" },
    { "source": "/api/get-conflict-zones", "destination": "/api/get-conflict-zones" },
    { "source": "/:path*", "destination": "/index.html" }
