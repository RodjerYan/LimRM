{
  "rewrites": [
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login"
    },
    {
      "source": "/api/auth/register",
      "destination": "/api/auth/register"
    },
    {
      "source": "/api/auth/verify",
      "destination": "/api/auth/verify"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth/me"
    },
    {
      "source": "/api/auth/logout",
      "destination": "/api/auth/logout"
    },
    {
      "source": "/api/gemini-proxy",
      "destination": "/api/gemini-proxy"
    },
    {
      "source": "/api/get-okb",
      "destination": "/api/get-okb"
    },
    {
      "source": "/api/get-okb-status",
      "destination": "/api/get-okb-status"
    },
    {
      "source": "/api/get-conflict-zones",
      "destination": "/api/get-conflict-zones"
    },
    {
      "source": "/api/get-full-cache",
      "destination": "/api/cache-ops?op=get-full"
    },
    {
      "source": "/api/add-to-cache",
      "destination": "/api/cache-ops?op=add"
    },
    {
      "source": "/api/update-coords",
      "destination": "/api/cache-ops?op=update-coords"
    },
    {
      "source": "/api/update-address",
      "destination": "/api/cache-ops?op=update-address"
    },
    {
      "source": "/api/delete-address",
      "destination": "/api/cache-ops?op=delete"
    },
    {
      "source": "/api/get-cached-address",
      "destination": "/api/cache-ops?op=get-one"
    },
    {
      "source": "/api/geocode",
      "destination": "/api/geocode"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/get-conflict-zones",
      "schedule": "0 6 * * *"
    }
  ]
}